<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="480">

    <headerText>Agregar ítem a la venta</headerText>

    <content>
        <VBox spacing="20">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="Seleccione un producto y complete la cantidad.&#10;Los campos con * son obligatorios."
                   wrapText="true"/>

            <GridPane hgap="20" vgap="14">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                </columnConstraints>

                <!-- Producto -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                    <Label text="* Producto"/>
                    <ComboBox fx:id="productComboBox" maxWidth="Infinity" promptText="Seleccione un producto..."/>
                    <Label fx:id="errorProduct" style="-fx-text-fill: #E63946; -fx-font-size: 11px;"/>
                </VBox>

                <!-- Precio unitario (readonly, se llena al seleccionar producto) -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Precio de venta (unitario)"/>
                    <TextField fx:id="unitPriceField" promptText="0.00" editable="false"
                               style="-fx-background-color: #F0F0F0;"/>
                    <Label fx:id="errorUnitPrice" style="-fx-text-fill: #E63946; -fx-font-size: 11px;"/>
                </VBox>

                <!-- Cantidad -->
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="* Cantidad"/>
                    <TextField fx:id="ammountField" promptText="1"/>
                    <Label fx:id="errorAmmount" style="-fx-text-fill: #E63946; -fx-font-size: 11px;"/>
                </VBox>

                <!-- Subtotal (readonly, calculado) -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                    <Label text="Subtotal"/>
                    <TextField fx:id="subtotalField" promptText="0.00" editable="false"
                               style="-fx-background-color: #F0F0F0; -fx-font-weight: bold;"/>
                </VBox>

            </GridPane>
        </VBox>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>

</DialogPane>
