<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mvcjava.sagt.javafx.controller.SalesController"
      spacing="15">

    <stylesheets>
        <URL value="@styles/mainView.css"/>
    </stylesheets>

    <!-- ── Barra de herramientas MASTER ──────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField promptText="Buscar venta..." prefWidth="250" styleClass="searchInput"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Agregar venta"   styleClass="btnPrimary" onAction="#handleAddSale"/>
        <Button text="Recargar"        styleClass="btnWarning" onAction="#handleReload"/>
        <Button text="Guardar cambios" styleClass="btnSuccess" onAction="#handleSaveChanges"/>
    </HBox>

    <SplitPane orientation="VERTICAL" VBox.vgrow="ALWAYS" dividerPositions="0.5">

        <!-- ── MASTER ──────────────────────────────────────────────────────── -->
        <TableView fx:id="salesTable" VBox.vgrow="ALWAYS">
            <columns/>
            <placeholder>
                <Label text="No hay ventas registradas"/>
            </placeholder>
        </TableView>

        <!-- ── DETAIL ──────────────────────────────────────────────────────── -->
        <VBox spacing="10">
            <padding>
                <Insets top="8" right="0" bottom="0" left="0"/>
            </padding>

            <!-- Barra de herramientas DETAIL -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="detailsLabel"
                       text="Seleccioná una venta para ver su detalle"
                       styleClass="sectionTitle"
                       HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!--
                    El botón "Agregar detalle" sólo se habilita cuando hay una venta
                    seleccionada; la lógica se maneja en SalesController.
                -->
                <Button fx:id="addDetailBtn"
                        text="Agregar ítem"
                        styleClass="btnPrimary"
                        onAction="#handleAddDetail"
                        disable="true"/>
            </HBox>

            <TableView fx:id="detailTable" VBox.vgrow="ALWAYS">
                <columns/>
                <placeholder>
                    <Label text="Seleccioná una venta para cargar sus ítems"/>
                </placeholder>
            </TableView>
        </VBox>

    </SplitPane>

</VBox>
